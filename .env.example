# Claude API Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_FAST=claude-sonnet-4-5-20250929
CLAUDE_MODEL_REASONING=claude-opus-4-6

# Database Configuration
DATABASE_URL=postgresql://compliance_user:compliance_pass@localhost:5432/compliance_db
PGVECTOR_DIMENSION=1536

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# NetSuite API Configuration
NETSUITE_ACCOUNT_ID=1234567
NETSUITE_CONSUMER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETSUITE_CONSUMER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETSUITE_TOKEN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETSUITE_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETSUITE_RESTLET_URL=https://1234567.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=123&deploy=1
NETSUITE_SEARCH_RESTLET_URL=https://1234567.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=124&deploy=1
NETSUITE_DEACTIVATION_RESTLET_URL=https://1234567.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=125&deploy=1

# Okta API Configuration
OKTA_DOMAIN=mycompany.okta.com
OKTA_API_TOKEN=00xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embeddings Configuration (choose one)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OR use Claude embeddings (no separate key needed)
EMBEDDING_PROVIDER=voyage  # or 'anthropic'

# Notification Configuration
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=compliance-alerts@yourcompany.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN_HERE
SLACK_CHANNEL=#compliance-alerts

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Scheduling Configuration
SCAN_INTERVAL_HOURS=4  # Run compliance scan every 4 hours
SCAN_TIMEZONE=America/New_York

# Risk Scoring Configuration
CRITICAL_THRESHOLD=90
HIGH_THRESHOLD=70
MEDIUM_THRESHOLD=40

# Notification Settings
NOTIFY_CRITICAL_IMMEDIATELY=true
NOTIFY_HIGH_DAILY=true
NOTIFY_MEDIUM_WEEKLY=true
NOTIFY_LOW_WEEKLY=true

# Slack Bot Configuration (for local Socket Mode integration)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# MCP Server Configuration (for Slack bot)
MCP_API_KEY=dev-key-12345

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# Feature Flags
ENABLE_VECTOR_SEARCH=true
ENABLE_HISTORICAL_ANALYSIS=true
ENABLE_ML_SCORING=false  # Future enhancement

# Rate Limiting
NETSUITE_API_RATE_LIMIT=10  # requests per second
CLAUDE_API_RATE_LIMIT=50    # requests per minute

# Development
DEBUG=false
ENVIRONMENT=development  # development, staging, production
